---
import Logo from "./Logo.astro";
import { REPO, repoBlob } from "~/data/site";
const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[var(--color-line)] bg-[var(--color-bg-subtle)]"
>
  <div class="container-page py-14">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-5">
      <div class="col-span-2">
        <a href="/" class="inline-flex"><Logo size={0} wordmark /></a>
        <p
          class="mt-4 max-w-xs text-[14px] leading-relaxed text-[var(--color-muted)]"
        >
          Type like Haskell, code like Ruby, scale like Erlang. Mutate when
          needs be, immutable otherwise.
        </p>
        <p class="mt-4 font-mono text-[12px] text-[var(--color-faint)]">
          MIT licensed. Built in C++20.
        </p>
      </div>

      <div>
        <h3
          class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]"
        >
          Learn
        </h3>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/examples">Examples</a
            >
          </li>
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/docs">Docs</a
            >
          </li>
          <!-- <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/tutorial">Tutorial</a
            >
          </li> -->
        </ul>
      </div>

      <div>
        <h3
          class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]"
        >
          Project
        </h3>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/install">Install</a
            >
          </li>
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href={REPO}>GitHub</a
            >
          </li>
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href={repoBlob("CHANGELOG.md")}>Changelog</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h3
          class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]"
        >
          Reference
        </h3>
        <ul class="mt-4 space-y-2.5 text-[14px]">
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/docs/syntax">Syntax</a
            >
          </li>
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/docs/types">Types</a
            >
          </li>
          <li>
            <a
              class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-accent-strong)]"
              href="/docs/stdlib">Prelude</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-[var(--color-line)] pt-6 sm:flex-row sm:items-center"
    >
      <p class="font-mono text-[12px] text-[var(--color-faint)]">
        © {year} kex.run
      </p>
      <p class="font-mono text-[12px] text-[var(--color-faint)]">
        <a
          class="transition-colors hover:text-[var(--color-accent-strong)]"
          href={repoBlob("LICENSE")}>MIT License</a
        >
      </p>
    </div>
  </div>
</footer>
