---
interface Props {
  size?: number;
  /** include the "kex" wordmark next to the mark */
  wordmark?: boolean;
  class?: string;
}

const { size = 28, wordmark = false, class: cls = "" } = Astro.props;
---

<span class:list={["inline-flex items-center gap-2", cls]}>
  {
    wordmark && (
      <span class="font-mono text-[18px] font-semibold tracking-[-0.02em] text-[var(--color-ink)]">
        kex<span class="text-[var(--color-accent)]">.run</span>
      </span>
    )
  }
</span>
