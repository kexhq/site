---
interface Props {
  size?: number;
  /** include the "kex" wordmark next to the mark */
  wordmark?: boolean;
  class?: string;
}

const { size = 28, wordmark = false, class: cls = "" } = Astro.props;
---

<span class:list={["inline-flex items-center gap-2", cls]}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 64 64"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="kexmark" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#ECB25E" />
        <stop offset="0.55" stop-color="#D28C36" />
        <stop offset="1" stop-color="#8a4f0a" />
      </linearGradient>
    </defs>
    <rect width="64" height="64" rx="14" fill="url(#kexmark)" />
    <path
      d="M22 16 L22 48 M22 34 L37 16 M22 32 L37 48"
      fill="none"
      stroke="#fff7e6"
      stroke-width="5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    <circle cx="43" cy="44" r="3.2" fill="#fff7e6" />
  </svg>
  {wordmark && (
    <span class="font-mono text-[18px] font-semibold tracking-[-0.02em] text-[var(--color-ink)]">
      kex<span class="text-[var(--color-accent)]">.so</span>
    </span>
  )}
</span>
