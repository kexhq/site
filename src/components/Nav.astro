---
import { REPO } from "~/data/site";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
};

const links = [
  { href: "/examples", label: "Examples" },
  { href: "/docs", label: "Docs" },
  { href: "/tutorial", label: "Tutorial" },
  { href: "/install", label: "Install" },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-transparent transition-[background,border-color,backdrop-filter] duration-200"
  data-scrolled="false"
>
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" class="font-display text-[20px] font-semibold tracking-[-0.02em] text-[var(--color-ink)]" aria-label="kex home">
      kex
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "rounded-lg px-3 py-1.5 text-[14px] font-medium transition-colors",
              isActive(l.href)
                ? "text-[var(--color-ink)] bg-[var(--color-bg-muted)]"
                : "text-[var(--color-muted)] hover:text-[var(--color-ink)] hover:bg-[var(--color-bg-subtle)]",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={REPO}
        class="hidden items-center gap-2 rounded-lg border border-[var(--color-line)] px-3 py-1.5 text-[13px] font-medium text-[var(--color-ink-soft)] transition-colors hover:border-[var(--color-line-strong)] hover:bg-[var(--color-bg-subtle)] sm:inline-flex"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.6.5.5 5.6.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17.3 4.6 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.9 1.2 1.9 1.2 3.2 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.6 18.4.5 12 .5z"/></svg>
        GitHub
      </a>

      <button
        type="button"
        id="nav-toggle"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-line)] text-[var(--color-ink-soft)] md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <div
    id="nav-mobile"
    class="hidden border-t border-[var(--color-line)] bg-[var(--color-bg)] md:hidden"
  >
    <nav class="container-page flex flex-col py-3" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "rounded-lg px-3 py-2.5 text-[15px] font-medium",
              isActive(l.href)
                ? "bg-[var(--color-bg-muted)] text-[var(--color-ink)]"
                : "text-[var(--color-ink-soft)]",
            ]}
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={REPO}
        class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-[var(--color-ink-soft)]"
      >GitHub</a>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    const toggle = document.getElementById("nav-toggle");
    const mobile = document.getElementById("nav-mobile");

    const onScroll = () => {
      if (!header) return;
      const scrolled = window.scrollY > 8;
      header.dataset.scrolled = String(scrolled);
      if (scrolled) {
        header.classList.add(
          "bg-[rgba(252,245,226,0.85)]",
          "backdrop-blur-xl",
          "border-[var(--color-line)]"
        );
      } else {
        header.classList.remove(
          "bg-[rgba(252,245,226,0.85)]",
          "backdrop-blur-xl",
          "border-[var(--color-line)]"
        );
      }
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    toggle?.addEventListener("click", () => {
      const open = mobile?.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(open));
    });
  })();
</script>
