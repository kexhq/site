---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { DOCS_NAV, DOC_ORDER, type DocEntry } from "~/data/docs";

interface Props {
  title: string;
  description?: string;
  /** slug of the current page, to highlight in the sidebar */
  current: string;
}

const { title, description, current } = Astro.props;
const currentPath = `/docs/${current}`;
const idx = DOC_ORDER.findIndex((e) => `/docs/${e.slug}` === currentPath);
const prev = idx > 0 ? DOC_ORDER[idx - 1] : null;
const next = idx >= 0 && idx < DOC_ORDER.length - 1 ? DOC_ORDER[idx + 1] : null;
---

<BaseLayout title={`${title} — kex docs`} description={description}>
  <div class="container-page py-10">
    <div class="grid gap-12 lg:grid-cols-[15rem_minmax(0,1fr)] lg:gap-16">
      <!-- sidebar -->
      <aside class="hidden lg:block">
        <nav class="sticky top-24 space-y-7" aria-label="Docs">
          {
            DOCS_NAV.map((section) => (
              <div>
                <p class="mb-2.5 font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]">
                  {section.heading}
                </p>
                <ul class="space-y-0.5">
                  {section.entries.map((e: DocEntry) => {
                    const href = e.slug.startsWith("../") ? `/${e.slug.replace("../", "")}` : `/docs/${e.slug}`;
                    const active = href === currentPath;
                    return (
                      <li>
                        <a
                          href={href}
                          class:list={[
                            "block rounded-md px-2.5 py-1.5 text-[13.5px] transition-colors",
                            active
                              ? "bg-[var(--color-accent-soft)] font-medium text-[var(--color-accent-ink)]"
                              : "text-[var(--color-muted)] hover:bg-[var(--color-bg-subtle)] hover:text-[var(--color-ink)]",
                          ]}
                        >
                          {e.title}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))
          }
        </nav>
      </aside>

      <!-- content -->
      <div class="min-w-0 max-w-3xl">
        <div class="mb-4 flex items-center gap-2 font-mono text-[12px] text-[var(--color-faint)]">
          <a href="/docs" class="hover:text-[var(--color-accent-strong)]">Docs</a>
          <span>/</span>
          <span class="text-[var(--color-muted)]">{title}</span>
        </div>

        <article class="prose-doc">
          <slot />
        </article>

        {
          (prev || next) && (
            <nav class="mt-16 grid gap-4 border-t border-[var(--color-line)] pt-6 sm:grid-cols-2">
              {prev ? (
                <a href={`/docs/${prev.slug}`} class="group rounded-xl border border-[var(--color-line)] p-4 transition-colors hover:border-[var(--color-line-strong)] hover:bg-[var(--color-bg-subtle)]">
                  <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]">← Previous</div>
                  <div class="mt-1 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent-strong)]">{prev.title}</div>
                </a>
              ) : <span />}
              {next ? (
                <a href={`/docs/${next.slug}`} class="group rounded-xl border border-[var(--color-line)] p-4 text-right transition-colors hover:border-[var(--color-line-strong)] hover:bg-[var(--color-bg-subtle)] sm:col-start-2">
                  <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]">Next →</div>
                  <div class="mt-1 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent-strong)]">{next.title}</div>
                </a>
              ) : <span />}
            </nav>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
