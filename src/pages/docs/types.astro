---
import DocsLayout from "~/layouts/DocsLayout.astro";
import Code from "~/components/Code.astro";
---

<DocsLayout
  title="Types"
  current="types"
  description="Records, sum types, Optional, and Result in kex."
>
  <h1>Types</h1>

  <p>
    Kex models data directly: <strong>records</strong> for product types,
    <strong><code>type</code></strong> for unions, <strong
      ><code>?</code></strong
    >
    for optional values, and <strong><code>Result</code></strong> for fallible flows.
  </p>

  <h2>Records</h2>
  <Code
    code={`record Temperature do
  celsius : Float

  static do
    let Freezing = Temperature { celsius: 0.0 }
  end
end

let boiling = Temperature { celsius: 100.0 }
let freezing = Temperature.Freezing
`}
    file="record.kex"
    source="examples/record.kex"
  />

  <h2>Sum types</h2>
  <Code
    code={`type ParseError = InvalidFormat(String) | Overflow | EmptyInput

let describe(e: ParseError) -> String do
  match e do
    InvalidFormat(s) -> "bad input: \${s}"
    Overflow         -> "out of range"
    EmptyInput       -> "got nothing"
  end
end`}
    file="union.kex"
    source="examples/union.kex"
  />

  <h2>Optional</h2>
  <p>
    <code>T?</code> is sugar for an optional value. Constructors are
    <code>Just(value)</code> and <code>None</code>. <code>.or(default)</code> unwraps
    with a fallback.
  </p>
  <Code
    code={`let findUserTodo(todos: [Todo], userId: Integer, todoId: Integer) -> Todo? do
  return todos.find { |t| t.id == todoId && t.userId == userId }
end

# Using T? sugar
let findUser(users: [User], name: String) -> User? do
  return users.find { |u| u.name == name }
end

let fallback = User { id: 0, name: "nobody", adult?: false, email: None }
let adult = users.find { |u| u.adult? }.or(fallback)
"adult email: \${adult.email}"        # String?`}
    file="optional.kex"
    source="examples/optional.kex"
  />

  <h2>Result</h2>
  <p>
    <code>Result&lt;T, E&gt;</code> is either <code>Ok(value)</code> or
    <code>Error(reason)</code>. The <code>?</code> operator returns early on an
    <code>Error</code>, unwrapping an <code>Ok</code>.
  </p>
  <Code
    code={`let parsePort(s: String) -> Result<Int, ParseError> do
  return Error(EmptyInput) if s.empty?
  
  match Integer.parse(s) do
    Ok(n)    -> do
      return Error(Overflow) if n > 65535
      return Ok(n)
    end
    Error(_) -> Error(InvalidFormat(s))
  end
end`}
    file="result.kex"
    source="examples/result.kex"
  />
  <p>
    <code>Result&lt;T, E&gt;</code> can also be simplified as <code
      >T or! E</code
    >.
  </p>
  <Code
    code={`let parsePort(s: String) -> Int or! ParseError do
  return Error(EmptyInput) if s.empty?
  
  match Integer.parse(s) do
    Ok(n)    -> do
      return Error(Overflow) if n > 65535
      return Ok(n)
    end
    Error(_) -> Error(InvalidFormat(s))
  end
end`}
    file="result.kex"
    source="examples/result.kex"
  />
</DocsLayout>
