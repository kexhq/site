---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { DOCS_NAV } from "~/data/docs";
---

<BaseLayout
  title="Docs — kex"
  description="The kex language documentation: syntax, types, functions, pattern matching, effects, traits, and the standard library."
>
  <section class="border-b border-[var(--color-line)] bg-[var(--color-bg-subtle)]">
    <div class="container-page py-14">
      <h1 class="text-[28px] font-semibold tracking-[-0.02em] text-[var(--color-ink)] sm:text-[32px]">
        Documentation
      </h1>
      <p class="mt-3 max-w-2xl text-[16px] leading-relaxed text-[var(--color-muted)]">
        A reference to kex, from your first
        <code class="font-mono text-[14px] text-[var(--color-ink)]">main</code> to
        type-directed <code class="font-mono text-[14px] text-[var(--color-ink)]">make</code> blocks
        and explicit effect boundaries.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        DOCS_NAV.map((section) => (
          <div>
            <h2 class="mb-4 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--color-faint)]">
              {section.heading}
            </h2>
            <ul class="space-y-1">
              {section.entries.map((e) => {
                const href = e.slug.startsWith("../") ? `/${e.slug.replace("../", "")}` : `/docs/${e.slug}`;
                return (
                  <li>
                    <a
                      href={href}
                      class="group block rounded-lg border border-transparent px-3 py-2.5 transition-colors hover:border-[var(--color-line)] hover:bg-[var(--color-bg-subtle)]"
                    >
                      <div class="text-[15px] font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent-strong)]">
                        {e.title}
                      </div>
                      {e.blurb && (
                        <div class="mt-0.5 text-[13.5px] text-[var(--color-muted)]">{e.blurb}</div>
                      )}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
