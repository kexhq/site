---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Code from "~/components/Code.astro";
import { EXAMPLES } from "~/data/examples";
import { REPO } from "~/data/site";

const heroExample = EXAMPLES.find((e) => e.slug === "vectors")!;
const purityExample = EXAMPLES.find((e) => e.slug === "purity")!;
const fizzbuzzExample = EXAMPLES.find((e) => e.slug === "fizzbuzz")!;
const streamExample = EXAMPLES.find((e) => e.slug === "streams")!;

// "Why kex" feature blocks — echoing the Ruby site's big extralight titles.
const WHY = [
  {
    title: "Pipelines",
    line: "Compose plain functions into fluent chains.",
    body:
      "Uniform Function Call Syntax means value.f(arg) is exactly f(value, arg). Plain functions chain like methods — no monkey-patching required.",
  },
  {
    title: "Purity",
    line: "Side effects stay visible in the type of the program.",
    body:
      "Functions are pure unless marked foul, and pure code can’t call foul code. main is the effect boundary; ? propagates failures without try/catch.",
  },
  {
    title: "Types",
    line: "Records, sum types, Optional, and Result.",
    body:
      "Model data directly with product records and type unions. Optional and Result carry absence and failure as values, with exhaustiveness-checked matching.",
  },
  {
    title: "Traits",
    line: "Contracts with defaults, behavior without classes.",
    body:
      "Declare required methods and ship default implementations. make X implement: Trait pulls them in — and you override individual methods where you want.",
  },
];
---

<BaseLayout>
  <!-- ===================== HERO ===================== -->
  <section class="relative overflow-hidden">
    <div class="container-page pt-14 pb-4 text-center sm:pt-20">
      <div class="flex justify-center">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img
            src="/logo.png"
            alt="kex"
            width="406"
            height="271"
            loading="eager"
            class="h-28 w-auto sm:h-36"
          />
        </picture>
      </div>

      <p
        class="mt-7 font-mono text-[11px] font-semibold uppercase tracking-[0.28em] text-[var(--color-accent-strong)]"
      >
        A small functional language
      </p>

      <h1
        class="mx-auto mt-4 max-w-3xl text-[40px] font-extrabold leading-[1.05] tracking-[-0.025em] text-[var(--color-ink)] sm:text-[56px]"
      >
        Kex is a small functional programming language.
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-[17px] leading-relaxed text-[var(--color-muted)]">
        Ruby-like syntax, immutable data by default, type-directed
        <code class="font-mono text-[15px] text-[var(--color-ink-soft)]">make</code> blocks,
        pattern matching, and explicit side-effect boundaries.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/install"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-6 py-3 text-[14.5px] font-bold uppercase tracking-wide text-white shadow-[0_10px_24px_-12px_rgba(138,79,10,0.7)] transition-transform hover:-translate-y-0.5"
        >
          Get started
        </a>
        <a
          href="/examples"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line-strong)] bg-[var(--color-bg)] px-6 py-3 text-[14.5px] font-semibold text-[var(--color-ink)] transition-colors hover:bg-[var(--color-bg-subtle)]"
        >
          Browse examples
        </a>
      </div>

      <p class="mt-5 font-mono text-[12.5px] text-[var(--color-faint)]">
        latest: v0.1 · MIT licensed · C++20
      </p>
    </div>

    <div class="container-page mt-12 max-w-3xl pb-16">
      <Code code={heroExample.code} output={heroExample.output} file="examples/vectors_advanced.kex" />
    </div>
  </section>

  <!-- ===================== WHY KEX ===================== -->
  <section class="bg-honey border-y border-[var(--color-line)]">
    <div class="container-page py-20 sm:py-24">
      <div class="mx-auto mb-12 max-w-2xl text-center sm:mb-16">
        <h2 class="text-[36px] font-extrabold tracking-[-0.025em] text-[var(--color-ink)] sm:text-[44px]">
          Why kex?
        </h2>
        <p class="mt-3 text-[16px] text-[var(--color-muted)]">
          The common path should feel light — pipelines, pure functions, typed
          records, and effects you can see.
        </p>
      </div>

      <div class="grid gap-x-12 gap-y-16 lg:grid-cols-2 lg:gap-x-20">
        {
          WHY.map((w) => (
            <div class="relative">
              <div class="relative mb-7 inline-block">
                <h3 class="text-[44px] font-medium leading-none tracking-tight text-[var(--color-accent-display)] sm:text-[56px]">
                  {w.title}
                </h3>
                <svg
                  class="absolute -bottom-3 left-0 h-3 w-[78%] text-[var(--color-accent)]"
                  viewBox="0 0 300 12"
                  fill="none"
                  preserveAspectRatio="none"
                  aria-hidden="true"
                >
                  <path
                    d="M2 8 Q 38 1, 76 8 T 152 8 T 228 8 T 298 8"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                  />
                </svg>
              </div>
              <p class="text-[18px] font-bold leading-snug text-[var(--color-ink)] sm:text-[20px]">
                {w.line}
              </p>
              <p class="mt-3 max-w-md text-[15px] leading-relaxed text-[var(--color-muted)]">
                {w.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== TOUR ===================== -->
  <section class="container-page grid gap-12 py-20 lg:grid-cols-2 lg:items-center">
    <div>
      <h2 class="text-[24px] font-bold tracking-[-0.01em] text-[var(--color-ink)]">
        Pattern matching
      </h2>
      <p class="mt-3 max-w-md text-[15.5px] leading-relaxed text-[var(--color-muted)]">
        Multi-clause functions, <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">match</code>
        expressions, destructuring, and guards. Branching reads top to bottom,
        and the compiler checks for exhaustiveness.
      </p>
    </div>
    <Code code={fizzbuzzExample.code} output={fizzbuzzExample.output} file="fizzbuzz.kex" />
  </section>

  <section class="bg-honey border-y border-[var(--color-line)]">
    <div class="container-page grid gap-12 py-20 lg:grid-cols-2 lg:items-center">
      <div class="lg:order-2">
        <h2 class="text-[24px] font-bold tracking-[-0.01em] text-[var(--color-ink)]">
          Purity, and effects you can see
        </h2>
        <p class="mt-3 max-w-md text-[15.5px] leading-relaxed text-[var(--color-muted)]">
          Functions are pure unless marked <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">foul</code>,
          and pure code can’t call foul code. <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">main</code>
          is the effect boundary; <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">?</code>
          propagates failures without try/catch.
        </p>
      </div>
      <div class="lg:order-1">
        <Code code={purityExample.code} output={purityExample.output} file="purity.kex" />
      </div>
    </div>
  </section>

  <section class="container-page grid gap-12 py-20 lg:grid-cols-2 lg:items-center">
    <div>
      <h2 class="text-[24px] font-bold tracking-[-0.01em] text-[var(--color-ink)]">
        Lazy streams and ranges
      </h2>
      <p class="mt-3 max-w-md text-[15.5px] leading-relaxed text-[var(--color-muted)]">
        Ranges and infinite streams share collection-style operations. Compose
        first — <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">filter</code>,
        <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">map</code>,
        <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">all?</code> — and
        pull only what you need with <code class="font-mono text-[14px] text-[var(--color-ink-soft)]">take</code>.
      </p>
    </div>
    <Code code={streamExample.code} output={streamExample.output} file="streams.kex" />
  </section>

  <!-- ===================== INSTALL ===================== -->
  <section class="bg-honey border-t border-[var(--color-line)]">
    <div class="container-page grid gap-10 py-20 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <h2 class="text-[24px] font-bold tracking-[-0.01em] text-[var(--color-ink)]">
          Build it from source
        </h2>
        <p class="mt-3 max-w-sm text-[15px] leading-relaxed text-[var(--color-muted)]">
          The compiler is written in C++20 with no external runtime dependencies.
          Requires CMake 3.20+ and a C++20 compiler.
        </p>
        <a
          href="/install"
          class="mt-4 inline-flex items-center gap-1.5 text-[14px] font-semibold text-[var(--color-accent-strong)] underline decoration-[var(--color-line-strong)] underline-offset-4 hover:decoration-current"
        >
          Full install guide
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="lg:col-span-7">
        <div class="surface-code overflow-hidden rounded-2xl border border-[var(--color-code-border)]">
          <div class="flex items-center gap-2 border-b border-[var(--color-code-border)] px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 font-mono text-[12px] text-[#a89a78]">bash</span>
          </div>
          <pre class="scroll-slim overflow-x-auto px-4 py-4 text-[13px] leading-[1.7] text-[#e9e0cf]"><code><span class="tok-fn">git</span> clone {REPO}.git <span class="tok-op">&&</span> <span class="tok-fn">cd</span> kex
<span class="tok-fn">make</span> build
<span class="tok-fn">make</span> run F=examples/fizzbuzz.kex
<span class="tok-fn">make</span> repl</code></pre>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
