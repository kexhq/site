---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Code from "~/components/Code.astro";
import { EXAMPLES } from "~/data/examples";
import { repoBlob } from "~/data/site";

const categories = ["Basics", "Types", "Control", "Effects", "DSL"] as const;
const grouped = categories
  .map((c) => ({ category: c, items: EXAMPLES.filter((e) => e.category === c) }))
  .filter((g) => g.items.length > 0);
---

<BaseLayout
  title="Examples — kex"
  description="A tour of Kex through runnable examples: records, UFCS pipelines, pattern matching, Result/Optional, lazy streams, traits, and DSLs."
>
  <section class="border-b border-[var(--color-line)] bg-[var(--color-bg-subtle)]">
    <div class="container-page py-14">
      <h1 class="text-[28px] font-semibold tracking-[-0.02em] text-[var(--color-ink)] sm:text-[32px]">
        Examples
      </h1>
      <p class="mt-3 max-w-2xl text-[16px] leading-relaxed text-[var(--color-muted)]">
        A tour of Kex through short, self-contained snippets — from
        <code class="font-mono text-[14px] text-[var(--color-ink)]">main</code> to
        type-directed <code class="font-mono text-[14px] text-[var(--color-ink)]">make</code> blocks.
        Each one is drawn from the language repo.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="flex flex-wrap gap-2" id="filter-bar">
      <button
        data-filter="all"
        class="filter-pill rounded-full border border-[var(--color-line)] bg-[var(--color-bg)] px-3.5 py-1.5 font-mono text-[12.5px] font-medium text-[var(--color-ink-soft)] transition-colors hover:border-[var(--color-line-strong)]"
        aria-pressed="true"
      >
        All
      </button>
      {
        categories.map((c) => (
          <button
            data-filter={c}
            class="filter-pill rounded-full border border-[var(--color-line)] bg-[var(--color-bg)] px-3.5 py-1.5 font-mono text-[12.5px] font-medium text-[var(--color-ink-soft)] transition-colors hover:border-[var(--color-line-strong)]"
            aria-pressed="false"
          >
            {c}
          </button>
        ))
      }
    </div>

    <div class="mt-12 space-y-20" id="example-list">
      {
        grouped.map((g) => (
          <div class="example-group" data-category={g.category}>
            <div class="mb-7 flex items-baseline justify-between gap-4 border-b border-[var(--color-line)] pb-3">
              <h2 class="font-mono text-[12px] uppercase tracking-[0.16em] text-[var(--color-faint)]">
                {g.category}
              </h2>
              <span class="font-mono text-[12px] text-[var(--color-faint)]">
                {g.items.length} {g.items.length === 1 ? "example" : "examples"}
              </span>
            </div>
            <div class="space-y-16">
              {g.items.map((ex) => (
                <article class="example-item scroll-mt-24" data-category={ex.category} id={ex.slug}>
                  <div class="grid gap-6 lg:grid-cols-12 lg:gap-10">
                    <div class="lg:col-span-4">
                      <h3 class="text-[20px] font-semibold tracking-[-0.01em] text-[var(--color-ink)]">
                        {ex.title}
                      </h3>
                      <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-muted)]">
                        {ex.tagline}
                      </p>
                      <a
                        href={repoBlob(ex.source)}
                        class="mt-3 inline-flex items-center gap-1.5 font-mono text-[12.5px] text-[var(--color-accent-strong)] hover:underline"
                      >
                        {ex.source}
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
                      </a>
                    </div>
                    <div class="lg:col-span-8">
                      <Code code={ex.code} output={ex.output} file={ex.source} />
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script is:inline>
  (function () {
    const pills = document.querySelectorAll<HTMLButtonElement>(".filter-pill");
    const items = document.querySelectorAll<HTMLElement>(".example-item");
    const groups = document.querySelectorAll<HTMLElement>(".example-group");

    const apply = (filter: string) => {
      pills.forEach((p) => {
        const active = p.dataset.filter === filter;
        p.setAttribute("aria-pressed", String(active));
        p.classList.toggle("bg-[var(--color-ink)]", active);
        p.classList.toggle("text-white", active);
        p.classList.toggle("border-[var(--color-ink)]", active);
      });

      items.forEach((it) => {
        const show = filter === "all" || it.dataset.category === filter;
        it.style.display = show ? "" : "none";
      });
      groups.forEach((g) => {
        const visible = Array.from(
          g.querySelectorAll<HTMLElement>(".example-item")
        ).filter((i) => i.style.display !== "none");
        g.style.display = visible.length ? "" : "none";
      });
    };

    pills.forEach((p) =>
      p.addEventListener("click", () => apply(p.dataset.filter ?? "all"))
    );
  })();
</script>
