---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Code from "~/components/Code.astro";

// Faux REPL transcript, kept as a string and rendered via set:html so the
// literal `{` / `${` characters in Kex source don't get parsed as expressions.
const replHtml = [
  `<span class="tok-comment"># Welcome to kex. Try an expression:</span>`,
  `<span class="tok-method">kex&gt;</span> <span class="tok-keyword">let</span> greet(name: String) <span class="tok-op">-&gt;</span> String <span class="tok-keyword">do</span>`,
  `     <span class="tok-keyword">return</span> <span class="tok-string">"Hello, \${"</span><span class="tok-op">$</span><span class="tok-punct">{</span>name<span class="tok-punct">}</span><span class="tok-string">"}!"</span>`,
  `   <span class="tok-keyword">end</span>`,
  `<span class="tok-method">kex&gt;</span> greet(<span class="tok-string">"world"</span>)`,
  `<span class="tok-op">&gt;</span> <span class="tok-string">"Hello, world!"</span>`,
  ``,
  `<span class="tok-method">kex&gt;</span> (<span class="tok-number">1</span>..<span class="tok-number">100</span>).reduce(<span class="tok-number">0</span>, <span class="tok-op">~</span>(<span class="tok-op">+</span>))`,
  `<span class="tok-op">&gt;</span> <span class="tok-number">5050</span>`,
  ``,
  `<span class="tok-method">kex&gt;</span> Stream.Sequence(from: <span class="tok-number">2</span>) { <span class="tok-op">|</span>n<span class="tok-op">|</span> n <span class="tok-op">+</span> <span class="tok-number">1</span> }`,
  `        .filter { <span class="tok-op">|</span>n<span class="tok-op">|</span> (<span class="tok-number">2</span>..<span class="tok-op">&gt;</span>n <span class="tok-op">-</span> <span class="tok-number">1</span>).all? { <span class="tok-op">|</span>d<span class="tok-op">|</span> n.modulo(d) <span class="tok-op">!=</span> <span class="tok-number">0</span> } }`,
  `        .take(<span class="tok-number">5</span>)`,
  `<span class="tok-op">&gt;</span> [<span class="tok-number">2</span>, <span class="tok-number">3</span>, <span class="tok-number">5</span>, <span class="tok-number">7</span>, <span class="tok-number">11</span>]`,
  ``,
  `<span class="tok-method">kex&gt;</span> <span class="inline-block h-[15px] w-[8px] translate-y-[2px] animate-pulse bg-[#bda4ff]"></span>`,
].join("\n");
---

<BaseLayout
  title="Tutorial — kex"
  description="An interactive, in-browser tutorial and REPL for kex. The interpreter is being compiled to WASM — coming soon."
>
  <section
    class="border-b border-[var(--color-line)] bg-[var(--color-bg-subtle)]"
  >
    <div class="container-page py-14">
      <div
        class="flex items-center gap-2 font-mono text-[12px] text-[var(--color-muted)]"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-accent)] opacity-50"
          ></span>
          <span
            class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-accent)]"
          ></span>
        </span>
        in-browser interpreter · in progress
      </div>
      <h1
        class="mt-3 text-[28px] font-semibold tracking-[-0.02em] text-[var(--color-ink)] sm:text-[32px]"
      >
        Tutorial &amp; REPL
      </h1>
      <p
        class="mt-3 max-w-2xl text-[16px] leading-relaxed text-[var(--color-muted)]"
      >
        The full kex interpreter is being compiled to WebAssembly with
        Emscripten, so the language can be learned entirely in the browser. This
        page will become a guided tutorial with a live REPL.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_18rem] lg:gap-10">
      <!-- Faux REPL preview -->
      <div>
        <div
          class="surface-code overflow-hidden rounded-2xl border border-[var(--color-code-border)] shadow-[0_18px_40px_-24px_rgba(13,12,40,0.45)]"
        >
          <div
            class="flex items-center gap-2 border-b border-[var(--color-code-border)] px-4 py-2.5"
          >
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            <span class="ml-2 font-mono text-[12px] text-[#8a8aa0]"
              >kex repl — wasm</span
            >
            <span
              class="ml-auto rounded-full bg-white/5 px-2 py-0.5 font-mono text-[10.5px] text-[#6b6b80]"
            >
              waiting on wasm build
            </span>
          </div>
          <pre
            class="scroll-slim overflow-x-auto px-5 py-5 font-mono text-[13px] leading-[1.75] text-[#d6d6e6]"><code set:html={replHtml} /></pre>
        </div>
        <p class="mt-4 text-center text-[13px] text-[var(--color-faint)]">
          A preview of the REPL UI. Live execution lands with the WASM build.
        </p>
      </div>

      <!-- sidebar: status + alternatives -->
      <aside class="space-y-6">
        <div class="rounded-2xl border border-[var(--color-line)] p-5">
          <h2
            class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]"
          >
            Build status
          </h2>
          <ul class="mt-3 space-y-2.5 text-[13.5px]">
            {
              [
                ["Tree-walk interpreter", true],
                ["Type checker", true],
                ["prelude in kex", true],
                ["Emscripten / WASM target", false],
                ["Guided browser lessons", false],
              ].map(([label, done]) => (
                <li class="flex items-start gap-2.5">
                  {done ? (
                    <svg
                      class="mt-0.5 shrink-0 text-[var(--color-accent)]"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                  ) : (
                    <svg
                      class="mt-0.5 shrink-0 text-[var(--color-faint)]"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <circle cx="12" cy="12" r="9" />
                      <path d="M12 7v6" />
                    </svg>
                  )}
                  <span
                    class={
                      done
                        ? "text-[var(--color-ink-soft)]"
                        : "text-[var(--color-muted)]"
                    }
                  >
                    {label}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-2xl border border-[var(--color-line)] p-5">
          <h2
            class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-faint)]"
          >
            In the meantime
          </h2>
          <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">
            Run the real interpreter locally to follow along with the examples.
          </p>
          <a
            href="/install"
            class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-[var(--color-ink)] px-3.5 py-2 text-[13px] font-semibold text-white transition-transform hover:-translate-y-0.5"
          >
            Install kex
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
            >
          </a>
        </div>
      </aside>
    </div>

    <!-- sample lesson preview -->
    <div class="mt-20">
      <div class="mx-auto max-w-2xl text-center">
        <p
          class="font-mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-accent-strong)]"
        >
          Lesson preview
        </p>
        <h2
          class="mt-3 text-[30px] font-semibold tracking-[-0.02em] text-[var(--color-ink)]"
        >
          Your first pipeline.
        </h2>
        <p class="mt-3 text-[16px] text-[var(--color-muted)]">
          A taste of the guided lessons that will accompany the REPL.
        </p>
      </div>
      <div class="mx-auto mt-10 max-w-2xl">
        <Code
          code={`# UFCS: value.f(arg) is the same as f(value, arg).
# That means plain functions chain like methods.

let nums = [1, 2, 3, 4, 5, 6]

let result = nums
  .filter(&.even?)            # [2, 4, 6]
  .map { |n| n * n }          # [4, 16, 36]
  .sum                        # 56

IO.printLine(result.to(String))`}
          output="56"
          file="lesson-01.kex"
        />
      </div>
    </div>
  </section>
</BaseLayout>
